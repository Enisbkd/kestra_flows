{
  "name": "fintrans-connector",
  "config": {
    "connector.class": "io.confluent.connect.s3.S3SinkConnector",
    "tasks.max": "1",
    "topics": "opera.financial-transactions",

    "s3.bucket.name": "kafka-sink",
    "s3.region": "us-east-1",
    "store.url": "http://minio:9000",

    "storage.class": "io.confluent.connect.s3.storage.S3Storage",
    "format.class": "io.confluent.connect.s3.format.json.JsonFormat",

    "partitioner.class": "io.confluent.connect.storage.partitioner.TimeBasedPartitioner",

    "timestamp.extractor": "RecordField",
    "timestamp.field": "updateDate",

    "partition.duration.ms": "86400000",
    "path.format": "YYYYMMdd",
    "timezone": "Europe/Paris",
    "locale": "fr-FR",

    "flush.size": "18",
    "rotate.interval.ms": "30000",

    "transforms": "convertTimestamp",
    "transforms.convertTimestamp.type": "org.apache.kafka.connect.transforms.TimestampConverter$Value",
    "transforms.convertTimestamp.field": "updateDate",
    "transforms.convertTimestamp.target.type": "Timestamp",
    "transforms.convertTimestamp.format": "yyyy-MM-dd HH:mm:ss",

    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}